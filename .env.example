# tflive runtime configuration example.
# Copy values from this file into your local environment or deployment secret manager.
# Lines marked optional can be omitted; the application will use the documented default.


# -----------------------------------------------------------------------------
# API server
# Used by cmd/tflive-api.
# -----------------------------------------------------------------------------

# Optional. Address the HTTP API listens on.
# Default: :8081
HTTP_ADDRESS=:8081


# -----------------------------------------------------------------------------
# Postgres
# Used by both cmd/tflive-api and cmd/tflive-worker.
# -----------------------------------------------------------------------------

# Required. Application database used for product metadata, run state, approvals,
# migrations, and log metadata as the product model grows.
# Local docker-compose default:
# postgres://tflive:tflive@localhost:55432/tflive_test?sslmode=disable
DATABASE_URL=postgres://tflive:tflive@localhost:55432/tflive_test?sslmode=disable


# -----------------------------------------------------------------------------
# Temporal
# Used by both cmd/tflive-api and cmd/tflive-worker.
# -----------------------------------------------------------------------------

# Required. Temporal frontend address.
# Local docker-compose default: localhost:7233
TEMPORAL_ADDRESS=localhost:7233

# Optional. Temporal namespace.
# Default: empty, which lets the Temporal client use its default namespace.
TEMPORAL_NAMESPACE=

# Optional. Task queue used by API dispatch and worker polling.
# Default: terraform-runs
TEMPORAL_TASK_QUEUE=terraform-runs


# -----------------------------------------------------------------------------
# Authentication and authorization services
# Used by the API runtime and local Compose services.
# -----------------------------------------------------------------------------

# API authentication and authorization runtime.
# Empty TFLIVE_ENVIRONMENT also means development; set production explicitly
# to enable HTTPS and OpenFGA credential enforcement.
TFLIVE_ENVIRONMENT=development
TFLIVE_TENANT_ID=tenant_123
VITE_TFLIVE_TENANT_ID=tenant_123

# Optional. Mock auth user role for local frontend development.
# Valid values: admin, operator, viewer
# When set, the app uses mock authentication instead of real OIDC.
# Omit for production deployment.
# VITE_TFLIVE_MOCK_USER_ROLE=admin
OIDC_ISSUER_URL=http://localhost:8082/realms/tflive
OIDC_AUDIENCE=tflive-api
OPENFGA_API_URL=http://localhost:8080

# Local development only. Production must provide every value below through a
# deployment secret manager and must not reuse these example credentials.
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak-local-only
KEYCLOAK_BOOTSTRAP_ADMIN_USERNAME=tflive-admin
KEYCLOAK_BOOTSTRAP_ADMIN_PASSWORD=tflive-admin-local-only
KEYCLOAK_WEB_REDIRECT_URIS=http://localhost:5173/,http://127.0.0.1:5173/
KEYCLOAK_WEB_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
KEYCLOAK_PLATFORM_ADMIN_USERNAME=tflive-platform-admin
KEYCLOAK_PLATFORM_ADMIN_PASSWORD=tflive-platform-admin-local-only
KEYCLOAK_PLATFORM_ADMIN_EMAIL=tflive-platform-admin@local.test
KEYCLOAK_PLATFORM_ADMIN_FIRST_NAME=tflive
KEYCLOAK_PLATFORM_ADMIN_LAST_NAME=Platform Administrator

# Required. Base URL for the Keycloak admin API. Used by the Keycloak provisioner.
# The provisioner authenticates with KEYCLOAK_ADMIN_USERNAME / _PASSWORD, which
# must be the same as KEYCLOAK_BOOTSTRAP_ADMIN_USERNAME / _PASSWORD above.
KEYCLOAK_ADMIN_URL=http://keycloak:8080
KEYCLOAK_ADMIN_USERNAME=tflive-admin
KEYCLOAK_ADMIN_PASSWORD=tflive-admin-local-only

# Optional. Admin realm to authenticate against. Default: master
# KEYCLOAK_ADMIN_REALM=master

# Optional. Target realm name. Default: tflive
# KEYCLOAK_REALM=tflive

# Optional. Browser-flow client ID. Default: tflive-web
# KEYCLOAK_WEB_CLIENT_ID=tflive-web

# Optional. API audience client ID. Default: tflive-api
# KEYCLOAK_API_CLIENT_ID=tflive-api

# Optional. HTTP client request deadline for Keycloak API calls. Default: 10s
# KEYCLOAK_HTTP_TIMEOUT=10s

OPENFGA_DB_NAME=openfga
OPENFGA_DB_USER=openfga
OPENFGA_DB_PASSWORD=openfga-local-only

# Generated by: docker compose run --rm openfga-provision bootstrap
# Copy the exact output here before running verify or starting the API.
OPENFGA_STORE_ID=
OPENFGA_MODEL_ID=

# Optional. Bearer credential when provisioning a protected OpenFGA deployment.
# The local OpenFGA service does not require one.
OPENFGA_API_TOKEN=

# Optional. OpenFGA store name used by the provisioner. Default: tflive
# OPENFGA_STORE_NAME=tflive

# Optional. Provisioning request deadline.
# Default: 10s
OPENFGA_HTTP_TIMEOUT=10s


# -----------------------------------------------------------------------------
# Worker local runtime
# Used by cmd/tflive-worker, and still used by cmd/tflive-api only when the
# filesystem artifact store is selected.
# -----------------------------------------------------------------------------

# Optional. Worker-private root for per-run working directories and local phase
# log spool files.
# Default: /tmp/tflive/runs
WORKER_RUN_ROOT=/tmp/tflive/runs


# -----------------------------------------------------------------------------
# Local MinIO
# Used by docker-compose for the local S3-compatible artifact store.
# -----------------------------------------------------------------------------

# Required by docker-compose minio and minio-init services.
MINIO_ROOT_USER=tflive
MINIO_ROOT_PASSWORD=tflive-secret


# -----------------------------------------------------------------------------
# Artifact store
# Used by both cmd/tflive-api and cmd/tflive-worker for durable phase logs.
# The API reads logs from this store, so production should use s3 instead of
# shared worker-local disk.
# -----------------------------------------------------------------------------

# Optional. Artifact store backend.
# Valid values: filesystem, s3
# Default: filesystem
ARTIFACT_STORE_KIND=s3

# Optional. Root directory for the filesystem artifact store.
# Used only when ARTIFACT_STORE_KIND=filesystem.
# Default: /tmp/tflive/artifacts
ARTIFACT_STORE_FILESYSTEM_ROOT=/tmp/tflive/artifacts


# -----------------------------------------------------------------------------
# S3-compatible artifact store
# Required only when ARTIFACT_STORE_KIND=s3.
# Use AWS S3 in production. For local S3-compatible services, set S3_ENDPOINT and
# S3_FORCE_PATH_STYLE=true.
# -----------------------------------------------------------------------------

# Required when ARTIFACT_STORE_KIND=s3. Bucket for run logs and future artifacts.
S3_BUCKET=tflive-artifacts

# Required when ARTIFACT_STORE_KIND=s3. AWS region or S3-compatible region value.
S3_REGION=us-east-1

# Optional. Custom S3-compatible endpoint.
# Leave empty for AWS S3, where the app defaults to https://s3.<S3_REGION>.amazonaws.com.
# Example for a local S3-compatible endpoint: http://localhost:9000
S3_ENDPOINT=http://localhost:9000

# Required when ARTIFACT_STORE_KIND=s3. Access key used by the current S3 adapter.
# Current adapter does not yet discover IAM role credentials automatically.
S3_ACCESS_KEY_ID=tflive

# Required when ARTIFACT_STORE_KIND=s3. Secret key used by the current S3 adapter.
S3_SECRET_ACCESS_KEY=tflive-secret

# Optional. Force path-style URLs like http://host/bucket/key.
# Usually false or empty for AWS S3. Usually true for local S3-compatible endpoints.
# Accepted true values: 1, true, yes, y, on
S3_FORCE_PATH_STYLE=true


# -----------------------------------------------------------------------------
# Test-only
# Used only by Go tests that exercise real Postgres migrations/repositories.
# -----------------------------------------------------------------------------

# Optional. Set to run Postgres integration tests locally.
# Example:
# tflive_POSTGRES_TEST_DSN=postgres://tflive:tflive@localhost:55432/tflive_test?sslmode=disable
tflive_POSTGRES_TEST_DSN=
